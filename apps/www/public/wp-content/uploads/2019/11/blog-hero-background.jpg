<script defer id="chaty-front-end-js" src="https://www.forestalparktenerife.es/wp-content/plugins/chaty/js/cht-front-script.min.js?ver=3.5.71691134724"></script>
<script data-ccm-injected="1" async data-wp-strategy="async" id="trustindex-loader-js-js" src="https://cdn.trustindex.io/loader.js?ver=1"></script>
<script id="recaptcha-api-js" src="https://www.google.com/recaptcha/api.js?render=explicit&#038;hl=es_ES&#038;onload=fusionOnloadCallback&#038;ver=7.15.4"></script>
<script id="fusion-scripts-js" src="https://www.forestalparktenerife.es/wp-content/uploads/fusion-scripts/80c577baa780d09c314284abc088b08d.min.js?ver=3.15.4"></script>
				<script type="text/javascript">
				jQuery( document ).ready( function() {
					var ajaxurl = 'https://www.forestalparktenerife.es/wp-admin/admin-ajax.php';
					if ( 0 < jQuery( '.fusion-login-nonce' ).length ) {
						jQuery.get( ajaxurl, { 'action': 'fusion_login_nonce' }, function( response ) {
							jQuery( '.fusion-login-nonce' ).html( response );
						});
					}
				});
				</script>
						<script type='text/javascript'>
						var active_captcha = [];

			var fusionOnloadCallback = function () {
				grecaptcha.ready( function () {
					jQuery( '.g-recaptcha-response' ).each( function () {
						var $el        = jQuery( this ),
							$container = $el.parent().find( 'div.recaptcha-container' ),
							id         = $container.attr( 'id' ),
							renderId;

						if ( 0 === $container.length || 'undefined' !== typeof active_captcha[ id ] || ( 1 === jQuery( '.fusion-modal' ).find( $container ).length && $container.closest( '.fusion-modal' ).is( ':hidden' ) ) ) {
							return;
						}

						renderId = grecaptcha.render(
							id,
							{
								sitekey: $container.data( 'sitekey' ),
								badge: $container.data( 'badge' ),
								size: 'invisible'
							}
						);

						active_captcha[ id ] = renderId;
						
						const $form = $el.closest( 'form' );
						if ( $form.hasClass( 'fusion-form' ) ) {
							const $submit = $form.find( '[type="submit"]' );

							$submit.attr( 'data-captcha-token', 'unset' ).on ( 'click', function( e ) {
								if ( 'unset' === jQuery( this ).attr( 'data-captcha-token' ) ) {
									e.preventDefault();

									grecaptcha.execute( renderId, { action: 'contact_form' } ).then( function ( token ) {
										$el.val( token );
										$submit.attr( 'data-captcha-token', 'received' );
										$form.trigger( 'submit' );

										setTimeout( function() {
											$el.empty();
											$submit.attr( 'data-captcha-token', 'unset' );
										}, 1000 );
									} );
								}
							} );
						} else {
							grecaptcha.execute( renderId, { action: 'contact_form' } ).then( function ( token ) {
								$el.val( token );
							} );
						}
					});
				});
			};
					</script>
		<script type="application/ld+json">{"@context":"https:\/\/schema.org","@type":["WebPage","FAQPage"],"mainEntity":[{"@type":"Question","name":"\u00bfPuedo realizar la actividad con mi mascota?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-2 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-18 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-6\"><p>Por el momento no es posible subir a las mascotas a los recorridos en altura, por lo que tu mascota disfrutar\u00e1 paseando por el bosque tal y como se ha indicado en el apartado anterior.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfPuedo llevar a mi mascota?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-3 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-19 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-7\"><p>En Forestal Park Tenerife somos amantes de los animales, por lo que las mascotas ser\u00e1n bienvenidas. Les pedimos que las mascotas siempre vayan atadas con la correa y acompa\u00f1ados por una persona responsable.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfQu\u00e9 pasa si cambia el tiempo mientras estamos disfrutando de las actividades?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-4 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-20 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-8\"><p>En caso de cambio brusco climatol\u00f3gico (p. ej. fuertes vientos y\/o lluvias, tormentas el\u00e9ctricas, riesgo de incendio, etc.), la Empresa se reserva el derecho de evacuar las instalaciones por seguridad. En tal supuesto, se ofrecer\u00e1 un cambio de d\u00eda para la realizaci\u00f3n de la actividad, siempre sujeto a disponibilidad.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfSe puede realizar la actividad si est\u00e1 lloviendo?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-5 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-21 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-9\"><p>La actividad se puede realizar lloviendo, siempre que no sean fuertes lluvias y se haya valorado que es seguro realizar la actividad. En d\u00edas de lluvia te recomendamos que traigas chubasquero y ropa de recambio ya que habr\u00e1 barro y agradecer\u00e1s ponerte algo seco al terminar.<\/p>\n<p>La aventura con lluvia se incrementa: <a href=\"https:\/\/youtu.be\/viQ9JVqr-aY\">https:\/\/youtu.be\/viQ9JVqr-aY<\/a><\/p>\n<p>En el supuesto de que la Empresa estime que la climatolog\u00eda es adecuada para realizar la actividad, los servicios reservados no podr\u00e1n ser anulados ni reembolsados, aun cuando no estuviera despejado o las condiciones atmosf\u00e9ricas no fueran totalmente id\u00f3neas.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfLos circuitos en altura y las tirolinas son accesibles para personas con diversidad funcional?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-6 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-22 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-10\"><p>Los participantes que presenten alg\u00fan tipo de discapacidad f\u00edsica (sensorial o de locomoci\u00f3n, permanente o temporal) o mental, o cualquier otra causa que necesite una atenci\u00f3n especial, rogamos que contacten con nosotros para estudiar la adaptaci\u00f3n de nuestras actividades a sus necesidades.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfLos circuitos en altura y las tirolinas son accesibles para personas en silla de ruedas?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-7 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-23 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-11\"><p>Los circuitos en altura y las tirolinas por el momento no son accesibles para personas con movilidad reducida que utilicen silla de ruedas.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfQu\u00e9 condiciones f\u00edsicas son necesarias para realizar las actividades?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-8 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-24 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-12\"><p>Las actividades requieren una m\u00ednima condici\u00f3n f\u00edsica para superar los juegos y retos en altura. Asimismo, los participantes no pueden presentar problemas f\u00edsicos de salud (p. ej. cardiopat\u00edas, problemas respiratorios, etc.) y aceptar\u00e1n que hay un riesgo de lesiones (p. ej. rasgu\u00f1os, golpes, contusiones, cortes, esguinces u otras lesiones) cuando se realizan las actividades.<\/p>\n<p>En caso de duda, te recomendamos que le consultes a tu m\u00e9dico si con X afecci\u00f3n puedes realizar las actividades de Forestal Park Tenerife.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfExiste un l\u00edmite m\u00e1ximo de edad para realizar las actividades del parque?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-9 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-25 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-13\"><p>El seguro de accidentes cubre hasta los 69 a\u00f1os, por lo tanto, es la edad m\u00e1xima permitida para realizar las actividades de Forestal Park Tenerife.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"Estoy embarazada, \u00bfpuedo realizar la actividad?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-10 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-26 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-14\"><p>No es recomendable que mujeres embarazas practiquen deportes de aventura con el fin de evitar golpes, presi\u00f3n en el abdomen o cualquier otro riesgo para el correcto desarrollo del beb\u00e9. Por razones de seguridad y extremando todas las precauciones, nuestra actividad no es apta para mujeres embarazadas.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"Tengo un ni\u00f1o menor de 5 a\u00f1os pero mide m\u00e1s de 1,10m o viceversa \u00bfpuede disfrutar de los recorridos en altura?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-11 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-27 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-15\"><p>Para acceder a los recorridos en altura los participantes deben tener cumplidos los 5 a\u00f1os y medir al menos 1,10m, por lo que, si no cumple uno de los dos requisitos comentados, habr\u00e1 que esperar a que cumpla los dos.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"Peso m\u00e1s de 110kg \u00bfpuedo realizar los recorridos en altura?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-12 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-28 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-16\"><p>Para acceder a los recorridos en altura los participantes ser\u00e1n equipados con <a href=\"https:\/\/www.petzl.com\/INT\/es\/Operadores\/Arneses\/PANJI\">arneses marca PETZL, modelo PANJI<\/a>, los cuales son talla \u00fanica que abarca un amplio rango de tallas, gracias a las regulaciones del cintur\u00f3n (hasta 120 cm) y de las perneras (hasta 75 cm). Es imprescindible que el arn\u00e9s se adapte correctamente a la morfolog\u00eda de su cuerpo para poder realizar la actividad y evitar el \u201cs\u00edndrome del arn\u00e9s\u201d en caso de quedarse colgado.<\/p>\n<p>En caso de que pese m\u00e1s de 110kg y el arn\u00e9s se adapte a su morfolog\u00eda, hay que tener en cuenta que como m\u00e1ximo se permiten 130kg.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfC\u00f3mo s\u00e9 que las instalaciones cumplen con la normativa de seguridad?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-13 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-29 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-17\"><p>Anualmente tanto las instalaciones de los recorridos en altura y las tirolinas como los \u00e1rboles soporte superan una inspecci\u00f3n externa que marca la norma europea de recorridos acrob\u00e1ticos en altura. Esta certificaci\u00f3n est\u00e1 visible en nuestra recepci\u00f3n y puedes consultarlo <a href=\"https:\/\/www.forestalparktenerife.es\/descargas\/es\/Certificado_Instalaciones_ARP_Forestal_Park_Tenerife.pdf\" target=\"_blank\" rel=\"noopener\">aqu\u00ed<\/a>.<\/p>\n<p>En cualquier caso, rogamos que consultes nuestra <a href=\"https:\/\/www.forestalparktenerife.es\/descargas\/es\/Normativa_Forestal_Park_Tenerife_parque_de_aventura_y_tirolinas.pdf\" target=\"_blank\" rel=\"noopener\">Normativa del Parque<\/a> para que conozcas todas las <a href=\"https:\/\/www.forestalparktenerife.es\/descargas\/es\/Documento_Condiciones_Participacion_Forestal_Park_Tenerife.pdf\" target=\"_blank\" rel=\"noopener\">Condiciones de Participaci\u00f3n<\/a> que hay que cumplir para disfrutar de una experiencia segura.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfTengo que llevar casco?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-14 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-30 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-18\"><p>La normativa europea de recorridos acrob\u00e1ticos en altura no obliga al uso de cascos ya que no es una actividad que entra\u00f1e un peligro para la zona que protege este elemento. En cualquier caso, si alg\u00fan participante necesita utilizar casco por alguna causa especial, contacta con nosotros para confirmarte la disponibilidad del material o darte las indicaciones pertinentes en relaci\u00f3n con tu caso.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfLa actividad es segura?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-15 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-31 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-19\"><p>Desde finales de 2016 trabajamos con un sistema de seguridad denominado \u201cl\u00ednea de vida continua\u201d, es decir, te conectas al inicio a un cable de seguridad \u201cl\u00ednea de vida\u201d que recorre todo el circuito y no te puedes desconectar hasta que aterrizas de nuevo en tierra.<\/p>\n<p>Antes de comenzar la actividad, recibir\u00e1s una charla de seguridad en un circuito de prueba donde los instructores explicar\u00e1n c\u00f3mo funciona este sistema, c\u00f3mo tienes que utilizar los elementos y qu\u00e9 pasos tienes que dar para realizar la actividad bajo los m\u00e1ximos est\u00e1ndares de seguridad.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfPuedo llevar mi c\u00e1mara de fotos y\/o v\u00eddeo durante la actividad?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-16 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-32 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-20\"><p>Puedes utilizar el m\u00f3vil, las c\u00e1maras de fotos y\/o v\u00eddeo, etc. siempre que tengas las manos libres para realizar la actividad. Te recomendamos que traigas tus dispositivos m\u00f3viles en una funda que puedas colgar del arn\u00e9s o del cuello. Los \u201cpalo-selfie\u201d est\u00e1n prohibidos.<\/p>\n<p>Recuerda compartir tus fotos y v\u00eddeos en las redes con el hashtag #forestalparktenerife y etiquetarnos.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfNos acompa\u00f1a un instructor durante la actividad?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-17 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-33 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-21\"><p>La actividad se realiza bajo autonom\u00eda vigilada, es decir, el instructor se encarga de supervisar el equipo de seguridad, ense\u00f1ar su manejo en el circuito de prueba y sube a los circuitos de forma puntual en caso de que necesiten ayuda. Desde tierra supervisan que todos los participantes y acompa\u00f1antes siguen las indicaciones y normas de Forestal Park Tenerife.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfQu\u00e9 necesito para disfrutar de la aventura en los \u00e1rboles?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-18 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-34 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-22\"><ul>\n<li>Obligatorio llevar el pelo largo recogido o tapado.<\/li>\n<li>Obligatorio usar zapatos deportivos cerrados que sujeten bien el pie. No permitidas las cholas\/chanclas, sandalias, ni los zapatos de tac\u00f3n.<\/li>\n<li>Obligatorio usar una camiseta que cubra la cintura.<\/li>\n<li>Evitar llevar pendientes, relojes, pulseras o piercings.<\/li>\n<li>Muy recomendable el uso de pantal\u00f3n largo.<\/li>\n<li>Muy recomendable el uso de guantes deportivos o mitones. En caso de que no tengas guantes, la actividad se puede realizar sin guantes.<\/li>\n<li>Siempre venir equipado con ropa de abrigo, ya que el pinar de Las Lagunetas es una zona muy fr\u00eda y h\u00fameda (en invierno la temperatura ronda los 10\u00baC y en verano oscila entre los 15\u00baC y los 30\u00baC).<\/li>\n<li>No hay servicio de taquillas y no se guardar\u00e1n sus pertenencias en recepci\u00f3n, recomendamos que traigan sus efectos personales en una ri\u00f1onera o en una mochila peque\u00f1a.<\/li>\n<\/ul>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfQu\u00e9 pasa si hay mucha cola en un recorrido?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-19 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-35 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-23\"><p>Los instructores de Forestal Park Tenerife intentan que los participantes fluyan por el parque sin formar colas y aglomeraciones. En cualquier caso, si hay un recorrido con mucha cola de espera, te recomendamos que busques otro circuito menos saturado y despu\u00e9s vayas a ese recorrido, hay 9 circuitos diferentes con m\u00e1s de 90 juegos distintos en altura para que disfrutes de una aventura inolvidable.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfPuedo abandonar la actividad sin completar las 3 horas de actividad?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-20 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-36 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-24\"><p>Los circuitos de Forestal Park Tenerife est\u00e1n dise\u00f1ados para que cada cierto tiempo aterrices en tierra y puedas descansar para continuar disfrutando de la aventura en los \u00e1rboles. En caso de que no puedas continuar realizando la actividad, cuando aterrices en uno de los recorridos, dir\u00edgete a nuestra recepci\u00f3n para ser desequipado y entregar el arn\u00e9s, aunque no hayas completado las 3 horas.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfSe puede estar m\u00e1s de 3 horas realizando los recorridos?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-21 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-37 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-25\"><p>Siempre que haya disponibilidad y que no sea el \u00faltimo turno del d\u00eda, podr\u00e1s pagar 5\u20ac extra por persona en nuestra recepci\u00f3n para ampliar el tiempo de disfrute una hora m\u00e1s.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfEn 3 horas se pueden realizar todos los circuitos de Forestal Park Tenerife?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-22 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-38 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-26\"><p>La duraci\u00f3n de 3 horas se ha establecido para realizar o los circuitos de dificultad f\u00e1cil y media o los circuitos de nivel dif\u00edcil o extremo, es decir, alrededor de 5 circuitos diferentes que combinen diferentes dificultades. En cualquier caso, al inicio de cada recorrido encontrar\u00e1s un cartel donde se se\u00f1ala la duraci\u00f3n estimada, la dificultad y los juegos que vas a realizar para que escojas a qu\u00e9 recorridos quieres ir.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfQu\u00e9 duraci\u00f3n tiene la actividad?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-23 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-39 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-27\"><p>La entrada general que da acceso a los circuitos en altura y las tirolinas, incluye 3 horas de diversi\u00f3n (media hora aproximadamente de formaci\u00f3n y 2 horas y media de aventura en los \u00e1rboles).<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfCon cu\u00e1nta antelaci\u00f3n a la hora de mi reserva tengo que estar en recepci\u00f3n?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-24 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-40 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-28\"><p>Para cumplir con todas las medidas de seguridad, rogamos que est\u00e9s en nuestra recepci\u00f3n 30 minutos antes de la hora de tu reserva para realizar tranquilamente el check in, equiparte con el arn\u00e9s y tener a todo el grupo listo para la hora en punto en la que se comenzar\u00e1 la actividad escuchando una charla de seguridad en un circuito de iniciaci\u00f3n.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfC\u00f3mo es la visita a Forestal Park Tenerife? 10 pasos para disfrutar de una experiencia inolvidable en la aventura en los \u00e1rboles y las tirolinas","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-25 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-41 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-29\"><ol>\n<li>Pueden aparcar su veh\u00edculo en el \u00e1rea de aparcamiento gratuito de Las Lagunetas (SIN VIGILANCIA). Recuerden no dejar nada de valor a la vista. La empresa no se responsabiliza por robos, p\u00e9rdidas o da\u00f1os causados a su veh\u00edculo.<\/li>\n<li>Un representante del grupo acceder\u00e1 a recepci\u00f3n para realizar el <em>check in<\/em> y formalizar el pago en caso de que estuviese pendiente.<\/li>\n<li>Organiza tus pertenencias (recuerda que NO hay taquillas) y prep\u00e1rense para comenzar con los primeros pasos para vivir una aventura memorable.<\/li>\n<li>Acceder\u00e1n al \u00e1rea de equipamiento para ponerles el arn\u00e9s y estar preparados para comenzar a disfrutar de la aventura en los \u00e1rboles.<\/li>\n<li>A la hora en punto, el personal de Forestal Park Tenerife impartir\u00e1 la charla de seguridad en un circuito de iniciaci\u00f3n para mostrarles c\u00f3mo desarrollar la actividad correctamente. A continuaci\u00f3n, todos los participantes realizar\u00e1n el circuito de prueba.<\/li>\n<li>Superado el circuito de prueba, comenzar\u00e1n a disfrutar de los recorridos en altura y las tirolinas, estando vigilados desde tierra por los instructores de Forestal Park Tenerife.<\/li>\n<li>En todo momento seguir\u00e1n las indicaciones facilitadas por el personal de Forestal Park Tenerife.<\/li>\n<li>Cuando finalice su tiempo deber\u00e1n dirigirse a Recepci\u00f3n para ser desequipados por el personal del Parque y entregar el arn\u00e9s y\/o material de seguridad.<\/li>\n<li>Comparte tu experiencia en las redes sociales con la etiqueta #forestalparktenerife.<\/li>\n<li>Planea tu pr\u00f3xima aventura \u00a1hasta pronto!<\/li>\n<\/ol>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"Tengo un bono regalo, \u00bfc\u00f3mo puedo canjearlo?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-26 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-42 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-30\"><p>Si has tenido la suerte de recibir una <a href=\"https:\/\/www.forestalparktenerife.es\/tarjeta-regalo\/\">Tarjeta Regalo<\/a> para disfrutar de la aventura en Forestal Park Tenerife, tienes que canjearlo para reservar las plazas el d\u00eda que quieras venir a visitarnos. Para ello existen diferentes v\u00edas:<\/p>\n<ul>\n<li>Si has recibido el bono regalo v\u00eda correo electr\u00f3nico, haz clic en el bot\u00f3n de \u201ccanjeo\u201d que aparece en dicho correo y sigue los pasos.<\/li>\n<li>En caso de que hayas recibido el bono regalo impreso, accede a nuestro apartado de tarjetas regalo y sigue las indicaciones para <a href=\"https:\/\/www.forestalparktenerife.es\/tarjeta-regalo\/\">Canjear tu Bono<\/a>.<\/li>\n<li>Por \u00faltimo, podemos canjear tu bono regalo de forma manual. Para ello env\u00eda un correo a <a href=\"mailto:reservas@forestalparktenerife.es\">reservas@forestalparktenerife.es<\/a> o env\u00eda un <a href=\"https:\/\/wa.me\/34630385742\">whatsapp<\/a> al <a href=\"https:\/\/wa.me\/34630385742\">630385742<\/a>, indicando el n\u00famero de reserva (F3-XXXXXX-X), as\u00ed como el d\u00eda y la hora en que desean realizar la actividad. Tambi\u00e9n pueden a\u00f1adir m\u00e1s participantes con los que compartir esta experiencia en la naturaleza.<\/li>\n<\/ul>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfSe pueden comprar entradas sin fecha, para regalar? \u00bftienen bonos regalo?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-27 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-43 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-31\"><p>Si, puedes adquirir un bono regalo que tendr\u00e1 un a\u00f1o de caducidad desde su fecha de compra.<\/p>\n<p>La forma m\u00e1s f\u00e1cil de adquirir un bono regalo es a trav\u00e9s de nuestro apartado dedicado a las <a href=\"https:\/\/www.forestalparktenerife.es\/tarjeta-regalo\/\">Tarjetas Regalo<\/a>\u00a0o haz clic en nuestro <a href=\"https:\/\/www.forestalparktenerife.es\/compra-aventura-tirolinas\/\">Calendario de Ventas Online<\/a>. En el calendario de compra marca la casilla de verificaci\u00f3n \u201clo quiero para regalar\u201d y sigue el proceso de compra. El bono regalo lo podr\u00e1s enviar directamente al correo electr\u00f3nico de la persona a la que quieres sorprender o puedes recibirlo en tu correo en formato PDF e imprimirlo para entregarlo en mano.<\/p>\n<p>En caso de que no pueda adquirir el bono regalo realizando la compra online, contacte con nosotros para utilizar otro m\u00e9todo de pago y generar el bono regalo de forma manual. Para hacer la compra de un bono regalo utilizando esta v\u00eda, se ruega que contacte con nosotros al menos con 24 horas de antelaci\u00f3n.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfPueden acompa\u00f1arme personas que no van a realizar la actividad? \u00bflos acompa\u00f1antes pagan entrada?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-28 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-44 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-32\"><p>Efectivamente pueden venir personas que no disfruten de las actividades para que vean desde los senderos c\u00f3mo realizas los recorridos en altura. Estos visitantes <strong>entrar\u00e1n de forma gratuita<\/strong> al parque, por lo que no hay que reservar entrada para ellos.<\/p>\n<p>Durante la celebraci\u00f3n de eventos, se limitar\u00e1 el acceso de estos acompa\u00f1antes a 1 por cada 4 participantes en la actividad. Asimismo, en caso de que los acompa\u00f1antes interfieran en la seguridad de los participantes en la aventura, se solicitar\u00e1 que esperen en la zona de Recepci\u00f3n o fuera de las instalaciones.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfCu\u00e1ndo pueden ir los ni\u00f1os solos durante el recorrido?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-29 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-45 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-33\"><p><strong>Los menores de 11 a\u00f1os<\/strong> nunca se pueden subir solos.<\/p>\n<p><strong>Los ni\u00f1os entre 11 y 12 a\u00f1os<\/strong> se pueden subir solos a los recorridos f\u00e1ciles (verdes) y medios (azules), vigilados por un adulto del grupo que mantenga contacto visual durante todo el tiempo que duren las Actividades.<\/p>\n<p><strong>A partir de 13 a\u00f1os<\/strong> pueden acceder a todos los circuitos solos, siempre y cuando cumplan con toda la normativa del parque.<\/p>\n<p>Visita nuestro <a href=\"https:\/\/www.forestalparktenerife.es\/circuitos-de-aventura\/\">Mapa de Circuitos de Tirolinas<\/a>,\u00a0 para m\u00e1s informaci\u00f3n sobre sus niveles de dificultad.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"Los adultos que acompa\u00f1an a los ni\u00f1os en altura, \u00bfpagan entrada? \u00bftienen que subir a los circuitos?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-30 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-46 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-34\"><p>Los adultos que acompa\u00f1an a los ni\u00f1os menores de 13 a\u00f1os durante los recorridos en altura pagan entrada y deben asegurarse de que los menores a su cargo realizan la actividad seg\u00fan las indicaciones de los instructores.<\/p>\n<p>En Forestal Park Tenerife los circuitos se dividen por colores seg\u00fan su nivel de dificultad: VERDE (f\u00e1cil), AZUL (medio), ROJO (dif\u00edcil) y NEGRO (extremo).<\/p>\n<p>En este sentido, en funci\u00f3n del nivel de dificultad del recorrido, los participantes tendr\u00e1n que cumplir con el siguiente requisito de altura:<\/p>\n<\/div>\n<div class=\"table-1\">\n<table width=\"100%\">\n<thead>\n<tr>\n<th align=\"left\"><b>NIVEL DE DIFICULTAD<\/b><\/th>\n<th align=\"left\"><b>ALTURA M\u00cdNIMA<\/b><\/th>\n<\/tr>\n<\/thead>\n<tbody>\n<tr>\n<td align=\"left\"><span style=\"color: #339966;\">F\u00e1cil (verde)<\/span><\/td>\n<td align=\"left\">A partir de 1,10m<\/td>\n<\/tr>\n<tr>\n<td align=\"left\"><span style=\"color: #0000ff;\">Medio (azul)<\/span><\/td>\n<td align=\"left\">A partir de 1,10m, excepto Circuito La Graciosa a partir de 1,30m<\/td>\n<\/tr>\n<tr>\n<td align=\"left\"><span style=\"color: #ff0000;\">Dif\u00edcil (rojo)<\/span><\/td>\n<td align=\"left\">A partir de 1,45m, excepto Circuito Fuerteventura a partir de 1,30m<\/td>\n<\/tr>\n<tr>\n<td align=\"left\"><span style=\"color: #000000;\">Extremo (negro)<\/span><\/td>\n<td align=\"left\">A partir de 1,45m<\/td>\n<\/tr>\n<\/tbody>\n<\/table>\n<\/div>\n<div class=\"fusion-text fusion-text-35\"><p>Visita nuestro <a href=\"https:\/\/www.forestalparktenerife.es\/circuitos-de-aventura\/\">Mapa con las dificultades de los circuitos de Tirolinas<\/a><\/p>\n<p>Por otro lado, los menores de 13 a\u00f1os siempre tendr\u00e1n que estar acompa\u00f1ados por un adulto en altura cumpliendo las siguientes ratios:<\/p>\n<ul>\n<li>\n<div class=\"RichText3-paragraph--withVSpacingNormal RichText3-paragraph Typography Typography--m\"><strong>Menores entre 5 y 8 a\u00f1os:<\/strong> acompa\u00f1ados en altura por un adulto cada 2 ni\u00f1os<\/div>\n<\/li>\n<li>\n<div class=\"RichText3-paragraph--withVSpacingNormal RichText3-paragraph Typography Typography--m\"><strong>Menores entre 9 y 10 a\u00f1os:<\/strong> acompa\u00f1ados en altura por un adulto cada 5 ni\u00f1os si realizan los circuitos f\u00e1ciles y medios. En caso de medir m\u00e1s de 1,45m y querer acceder a los circuitos dif\u00edciles y extremo, cada 3 ni\u00f1os se tienen que subir 1 adulto en altura.<\/div>\n<\/li>\n<li>\n<div class=\"RichText3-paragraph--withVSpacingNormal RichText3-paragraph Typography Typography--m\"><strong>Menores entre 11 y 12 a\u00f1os:<\/strong> pueden subirse solos a los recorridos f\u00e1ciles (verdes) y medios (azules), vigilados por un adulto del grupo que mantenga contacto visual durante todo el tiempo que duren las Actividades. Para subir a los circuitos dif\u00edciles (rojos) y extremo (negro) deben ir acompa\u00f1ados en altura por un adulto cada 3 ni\u00f1os.<\/div>\n<\/li>\n<\/ul>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"Modificaci\u00f3n de reservas, cancelaciones y devoluciones","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-31 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-47 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-36\"><p><strong>Hasta 48 horas antes de tu actividad<\/strong> podr\u00e1s modificar o cancelar tu reserva sin recargo. En caso de cancelar tu reserva, recibir\u00e1s el importe completo del prepago o del pago de las entradas.<\/p>\n<p><strong>Hasta 24 horas antes de tu actividad<\/strong> podr\u00e1s modificar la fecha de tu reserva sujeta a disponibilidad, esta modificaci\u00f3n no incurrir\u00e1 ning\u00fan gasto. En caso de cancelar tu reserva, se retendr\u00e1 el 100% del importe (no habr\u00e1 devoluci\u00f3n). En todo caso, se pueden realizar hasta 3 modificaciones de reserva en el plazo m\u00e1ximo de 1 a\u00f1o.<\/p>\n<p><strong>En caso de \u201cno-show\u201d<\/strong>, es decir, no asistir el d\u00eda de tu reserva, no se podr\u00e1 modificar tu reserva ni se realizar\u00e1 el reembolso del prepago o el pago de las entradas.<\/p>\n<p>En caso de que las instalaciones tengan que cerrarse por una causa de fuerza mayor (por ejemplo: fen\u00f3menos meteorol\u00f3gicos adversos, confinamiento, etc.), se realizar\u00e1 el reembolso completo del importe que haya abonado de su reserva.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfSe puede pagar a trav\u00e9s de Bizum?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-32 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-48 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-37\"><p>Por el momento no tenemos activa est\u00e1 opci\u00f3n, por lo que la forma m\u00e1s sencilla de reservar es realizando la compra online a trav\u00e9s de nuestro <a href=\"https:\/\/www.forestalparktenerife.es\/compra-aventura-tirolinas\/\">Calendario de Venta de Entradas<\/a>.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfSe puede pagar en efectivo y\/o con tarjeta en recepci\u00f3n?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-33 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-49 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-38\"><p>En el momento de realizar su reserva se solicitar\u00e1 que realice la <a href=\"https:\/\/www.forestalparktenerife.es\/compra-aventura-tirolinas\/\">Compra Online de las Entradas<\/a> o realizar un prepago v\u00eda transferencia bancaria al menos del 30% del porcentaje del presupuesto de su reserva. En el segundo supuesto, el resto del pago se podr\u00e1 realizar en nuestra Recepci\u00f3n tanto en tarjeta como en efectivo presentando el importe exacto.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfPuedo reservar el mismo d\u00eda?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-34 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-50 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-39\"><p>Siempre que haya disponibilidad se puede reservar <strong>hasta una hora y media antes del comienzo de la actividad<\/strong>.<\/p>\n<p>La forma m\u00e1s r\u00e1pida de reservar es comprando las entradas a trav\u00e9s de nuestro <a href=\"https:\/\/www.forestalparktenerife.es\/compra-aventura-tirolinas\/\">Calendario de Ventas Online<\/a>.<\/p>\n<p>La conexi\u00f3n telef\u00f3nica en el Paisaje Protegido de Las Lagunetas donde se encuentra ubicado el parque da muchos problemas ya que trabajamos con conexi\u00f3n v\u00eda sat\u00e9lite, por lo que, si no realizas la compra online, te recomendamos que contactes con nuestro equipo a trav\u00e9s del <a href=\"https:\/\/wa.me\/34630385742\">whatsapp 630385742<\/a> en horario de 9:30h a 18:00h en invierno (de noviembre a marzo) o de 9:30h a 19:00h en verano (de abril a octubre).<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfCon cu\u00e1nta antelaci\u00f3n tengo que realizar la reserva?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-35 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-51 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-40\"><p>Depende de la temporada, el d\u00eda, la hora y el tipo de grupo y de actividad que te gustar\u00eda reservar:<\/p>\n<ul>\n<li><strong>De octubre a marzo<\/strong>, para entradas individuales recomendamos reservar con al menos 5 d\u00edas de antelaci\u00f3n. Para grupos y eventos, recomendamos reservar al menos con 10 d\u00edas de antelaci\u00f3n.<\/li>\n<li><strong>De abril a septiembre<\/strong>, para entradas individuales recomendamos reservar con 10 d\u00edas de antelaci\u00f3n. Para grupos y eventos, recomendamos reservar al menos con 20 d\u00edas de antelaci\u00f3n.<\/li>\n<li><strong>Para venir en vacaciones escolares<\/strong> (\u00e9poca Navide\u00f1a, puentes y festivos, as\u00ed como durante las vacaciones de verano), recomendamos reservar las entradas individuales al menos con 10 d\u00edas de antelaci\u00f3n.<\/li>\n<\/ul>\n<p>En cualquier caso, siempre puede comprobar la disponibilidad a tiempo real accediendo a nuestro <a href=\"https:\/\/www.forestalparktenerife.es\/compra-aventura-tirolinas\/\">Calendario de Venta Online<\/a>.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"En el calendario de compra solo me deja escoger X adultos o X ni\u00f1os \u00bfhay un error?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-36 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-52 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-41\"><p>Si est\u00e1s realizando la compra online en nuestro calendario de venta y solo te deja escoger X adultos pero no te deja escoger m\u00e1s o no te deja escoger X ni\u00f1os, o viceversa, quiere decir que quedan pocas plazas y no hay suficientes para seleccionar toda las entradas que necesitas ese d\u00eda a esa hora.<\/p>\n<p>En este caso puedes seleccionar otra hora u otra fecha y hora que est\u00e9n en verdes en nuestro <a href=\"https:\/\/www.forestalparktenerife.es\/compra-aventura-tirolinas\/\">Calendario de Venta de Entradas Online<\/a>.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfC\u00f3mo puedo hacer una reserva?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-37 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-53 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-42\"><p><strong>Actualmente es obligatorio realizar reserva con antelaci\u00f3n.<\/strong><\/p>\n<p>Puedes reservar tus entradas ahora <a href=\"https:\/\/www.forestalparktenerife.es\/compra-aventura-tirolinas\/\">aqu\u00ed<\/a>.<\/p>\n<p>En caso de que quieras reservar una fiesta de cumplea\u00f1os infantil o de adultos, una despedida de soltero\/a, una visita escolar, un evento de empresa o cualquiera de las otras opciones para grupos que te ofrecemos en nuestra web, puedes contactar directamente con el equipo de Forestal Park Tenerife a trav\u00e9s del correo <a href=\"mailto:reservas@forestalparktenerife.es\">reservas@forestalparktenerife.es<\/a> o envi\u00e1ndonos un <a href=\"https:\/\/wa.me\/34630385742\">whatsapp<\/a> al <a href=\"https:\/\/wa.me\/34630385742\">630385742<\/a>.<\/p>\n<p>La atenci\u00f3n telef\u00f3nica es muy limitada ya que en el espacio natural en el que se encuentra ubicado el parque no hay cobertura, por lo que tenemos conexi\u00f3n telef\u00f3nica v\u00eda sat\u00e9lite y hay ocasiones en la que tenemos dificultades con las comunicaciones.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}},{"@type":"Question","name":"\u00bfC\u00f3mo s\u00e9 si mi reserva es correcta?","acceptedAnswer":{"@type":"Answer","text":"<div class=\"fusion-fullwidth fullwidth-box fusion-builder-row-5-38 fusion-flex-container has-pattern-background has-mask-background nonhundred-percent-fullwidth non-hundred-percent-height-scrolling\" style=\"--awb-border-radius-top-left:0px;--awb-border-radius-top-right:0px;--awb-border-radius-bottom-right:0px;--awb-border-radius-bottom-left:0px;--awb-flex-wrap:wrap;\" ><div class=\"fusion-builder-row fusion-row fusion-flex-align-items-flex-start fusion-flex-content-wrap\" style=\"width:104% !important;max-width:104% !important;margin-left: calc(-4% \/ 2 );margin-right: calc(-4% \/ 2 );\"><div class=\"fusion-layout-column fusion_builder_column fusion-builder-column-54 fusion_builder_column_1_1 1_1 fusion-flex-column\" style=\"--awb-bg-size:cover;--awb-width-large:100%;--awb-flex-grow:0;--awb-flex-shrink:0;--awb-margin-top-large:0px;--awb-spacing-right-large:1.92%;--awb-margin-bottom-large:0px;--awb-spacing-left-large:1.92%;--awb-width-medium:100%;--awb-order-medium:0;--awb-flex-grow-medium:;--awb-flex-shrink-medium:;--awb-spacing-right-medium:1.92%;--awb-spacing-left-medium:1.92%;--awb-width-small:100%;--awb-order-small:0;--awb-flex-grow-small:;--awb-flex-shrink-small:;--awb-spacing-right-small:1.92%;--awb-spacing-left-small:1.92%;\"><div class=\"fusion-column-wrapper fusion-column-has-shadow fusion-flex-justify-content-flex-start fusion-content-layout-column\"><div class=\"fusion-text fusion-text-43\"><p>Si has comprado una entrada online o contactado con nosotros por alguna de las diferentes v\u00edas de contacto que ponemos a tu disposici\u00f3n, cuando la reserva se complete recibir\u00e1s un correo en el que aparecer\u00e1 el c\u00f3digo de tu reserva que comienza por F3-\u2026, el d\u00eda, la fecha y toda la informaci\u00f3n relativa a tu aventura en Forestal Park Tenerife.<\/p>\n<p>En caso de que no recibas este correo, contacta con nosotros a trav\u00e9s del correo <a href=\"mailto:reservas@forestalparktenerife.es\">reservas@forestalparktenerife.es<\/a> o envi\u00e1ndonos un <a href=\"https:\/\/wa.me\/34630385742\">whatsapp<\/a> al <a href=\"https:\/\/wa.me\/34630385742\">630385742<\/a>.<\/p>\n<p>La atenci\u00f3n telef\u00f3nica es muy limitada ya que en el espacio natural en el que se encuentra ubicado el parque no hay cobertura, por lo que tenemos conexi\u00f3n telef\u00f3nica v\u00eda sat\u00e9lite y hay ocasiones en la que tenemos dificultades con las comunicaciones.<\/p>\n<\/div><\/div><\/div><\/div><\/div>\n"}}]}</script><script type="text/javascript" charset="UTF-8" data-cs-platform="wordpress" src="https://cdn.cookie-script.com/s/af02583ab4ba23e1bc9240c8dad26fde.js" id="cookie_script-js-with"></script><script id="js-turitop" src="https://app.turitop.com/js/load-turitop.min.js" data-company="F3" data-ga="no" data-buttoncolor="green" data-afftag="ttafid" ></script>		</div>

