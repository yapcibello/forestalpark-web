---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '@fp/config';

// Placeholder de la home EN (/en/) — esqueleto fase `estructura`.
// Los slugs EN son traducidos; las páginas reales se crean file-based en la
// fase de migración.
---

<Layout title={siteConfig.title} description={siteConfig.description} lang="en">
  <main class="mx-auto max-w-3xl p-8">
    <h1 class="font-heading text-3xl text-primary">{siteConfig.name}</h1>
    <p class="mt-4 text-secondary">
      Monorepo skeleton under construction. Content is migrated in a later phase.
    </p>
  </main>
</Layout>
