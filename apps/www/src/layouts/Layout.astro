---
import '../styles/global.css';

// Layout base — esqueleto fase `estructura`.
// El layout definitivo (Header/Footer de @fp/ui, SEO meta de @fp/seo,
// GTM + Consent Mode v2, hreflang) se implementa en fases posteriores.

interface Props {
  title: string;
  description?: string;
  lang?: 'es' | 'en';
}

const { title, description = '', lang = 'es' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <slot />
  </body>
</html>
