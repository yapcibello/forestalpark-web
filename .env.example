# Credenciales de deploy FTP/FTPS a producción (Forestal Park Tenerife).
# Copia este archivo a .env y rellena los valores reales. .env NO se versiona.
FTP_HOST=
FTP_USER=
FTP_PASS=
FTP_REMOTE_DIR=/public_html/
# 'yes' si conectas por dominio con cert válido; 'no' si conectas por IP.
FTP_CHECK_HOSTNAME=no

# GTM (contenedor existente del cliente — ya embebido en los snapshots).
PUBLIC_GTM_ID=GTM-PRDC87D3
